# Server
PORT=8000

# MongoDB connection string (database name is appended automatically)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# JWT secrets and expiries
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace-with-another-long-random-string
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary (profile picture uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Comma-separated list of allowed frontend origins (localhost is always allowed).
# Example for production:
# CORS_ORIGIN=https://quiz-master-wp32.onrender.com
CORS_ORIGIN=https://quiz-master-wp32.onrender.com
